# ISOTOPE MCP Server Configuration
# Model Context Protocol - Enhanced AI Capabilities

{
  "mcpServers": {
    "isotope-core": {
      "command": "python3",
      "args": ["/root/isotope/mcp_servers/core_server.py"],
      "env": {
        "ISOTOPE_VERSION": "3.0",
        "BACKEND_URL": "http://185.167.97.193:8100"
      }
    },
    "isotope-research": {
      "command": "python3",
      "args": ["/root/isotope/mcp_servers/research_server.py"],
      "env": {
        "RESEARCH_MODE": "realtime",
        "DATA_SOURCES": "tradingview,coingecko,forexfactory,reuters"
      }
    },
    "isotope-execution": {
      "command": "python3",
      "args": ["/root/isotope/mcp_servers/execution_server.py"],
      "env": {
        "EXECUTION_MODE": "24/7",
        "MAX_LATENCY_MS": "5"
      }
    },
    "isotope-optimizer": {
      "command": "python3",
      "args": ["/root/isotope/mcp_servers/optimizer_server.py"],
      "env": {
        "OPTIMIZATION_TARGET": "sharpe_ratio",
        "REBALANCE_FREQUENCY": "hourly"
      }
    }
  },
  "capabilities": {
    "realtime_research": true,
    "autonomous_execution": true,
    "self_optimization": true,
    "multi_agent_coordination": true,
    "kalshi_market_making": true,
    "sentiment_analysis": true,
    "risk_management": true,
    "performance_tracking": true
  }
}
