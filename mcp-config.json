{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/root/isotope"],
      "env": {},
      "description": "Full filesystem access for ISOTOPE project"
    },
    "search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {},
      "description": "Code search and repository access"
    },
    "gold-sentiment": {
      "command": "python3",
      "args": ["-m", "mcp_server_sentiment"],
      "env": {
        "SENTIMENT_SOURCES": "reuters,kitco,bloomberg,gold.org"
      },
      "description": "Real-time gold sentiment analysis from news feeds"
    }
  },
  "resources": {
    "gold-price-feed": {
      "uri": "wss://api.tradingview.com/xauusd/live",
      "type": "websocket",
      "refreshInterval": 1000
    },
    "news-sentiment": {
      "uri": "https://api.reuters.com/gold/news",
      "type": "rest",
      "refreshInterval": 60000
    }
  },
  "tools": {
    "fetch_gold_price": {
      "description": "Fetch real-time XAU/USD price data",
      "inputSchema": {
        "timeframe": "1m|5m|15m|1h|4h|1d"
      }
    },
    "analyze_sentiment": {
      "description": "Analyze gold market sentiment from news sources",
      "inputSchema": {
        "sources": "array of news sources",
        "timeRange": "1h|6h|24h"
      }
    },
    "backtest_signal": {
      "description": "Backtest trading signal against historical data",
      "inputSchema": {
        "strategy": "string",
        "startDate": "ISO date",
        "endDate": "ISO date"
      }
    }
  }
}
