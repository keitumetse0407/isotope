# ISOTOPE Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real secrets

# ============================================
# META API (TradingView/MetaTrader Integration)
# ============================================
META_API_KEY=meta_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
META_API_URL=wss://api.metatrader.com/v2
META_DEMO_MODE=true

# ============================================
# UPSTASH REDIS (Caching & Session Storage)
# ============================================
UPSTASH_REDIS_URL=https://xxxxx-xxxxx-xxxxx.upstash.io
UPSTASH_REDIS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# OPENROUTER (LLM Sentiment Analysis)
# ============================================
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# ALPHA VANTAGE (Gold Price Data Backup)
# ============================================
ALPHA_VANTAGE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# WHATSAPP NOTIFICATION BOT
# ============================================
WHATSAPP_BOT_URL=http://113.30.189.89:8765/api/send
WHATSAPP_BOT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# ISOTOPE CORE CONFIG
# ============================================
NODE_ENV=production
LOG_LEVEL=info
PORT=8100
DASHBOARD_PORT=8101

# Signal Processing
MAX_LATENCY_MS=10
MAX_RECONNECT_ATTEMPTS=5
RECONNECT_BASE_DELAY_MS=1000

# Risk Management
DEFAULT_RISK_PERCENT=1.0
MAX_DAILY_SIGNALS=20
MIN_CONFIDENCE_THRESHOLD=0.7

# ============================================
# DATABASE (SQLite for persistence)
# ============================================
DATABASE_PATH=/root/isotope/data/isotope.db

# ============================================
# MONITORING & ALERTING
# ============================================
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
HEALTHCHECK_URL=https://hc-ping.com/xxxxx-xxxxx-xxxxx
